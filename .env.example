# Required server-only configuration
MONGODB_URI=<NEW_ROTATED_MONGODB_URI>
MONGODB_DB_NAME=artdera
AUTH_SECRET=<GENERATE_AT_LEAST_32_RANDOM_CHARACTERS>
APP_URL=http://localhost:3000
# Optional comma-separated additional browser origins. Same-origin Vercel
# preview URLs are accepted automatically.
ALLOWED_ORIGINS=https://artdera.com,https://www.artdera.com,https://artdera-global-canvas.vercel.app
API_PORT=3001
NODE_ENV=development

# Development adapters. Disable both in production.
DEMO_PAYMENT_MODE=true
PAYMENT_PROVIDER=demo
DEMO_OTP_MODE=true
DEMO_OTP_CODE=123456

# Upload adapter
# Use local for development. Use mongodb on Vercel for persistent GridFS storage.
UPLOAD_PROVIDER=local
UPLOAD_DIR=uploads
MAX_ARTWORK_IMAGE_SIZE_MB=10
MAX_PROFILE_IMAGE_SIZE_MB=5

# Optional seed accounts; never use known credentials in production.
SEED_DEMO_DATA=true
DEMO_ARTIST_EMAIL=artist@artdera.demo
DEMO_ARTIST_PASSWORD=<SET_FOR_LOCAL_SEEDING>
DEMO_GALLERY_EMAIL=gallery@artdera.demo
DEMO_GALLERY_PASSWORD=<SET_FOR_LOCAL_SEEDING>
DEMO_BUYER_EMAIL=buyer@artdera.demo
DEMO_BUYER_PASSWORD=<SET_FOR_LOCAL_SEEDING>
DEMO_ADMIN_EMAIL=admin@artdera.demo
DEMO_ADMIN_PASSWORD=<SET_FOR_LOCAL_SEEDING>

# Explicit admin:create command only
ADMIN_NAME=ArtDera Administrator
ADMIN_EMAIL=<ADMIN_EMAIL>
ADMIN_PASSWORD=<GENERATE_AT_LEAST_14_RANDOM_CHARACTERS>

# Provider credentials belong only in an uncommitted environment file or the
# Vercel environment-variable store.
EMAIL_PROVIDER=console
UPLOAD_PUBLIC_BASE_URL=http://localhost:3001/uploads
